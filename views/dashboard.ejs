<%- include('partials/head', { title, useThree: false }) %>

<!-- Dashboard — full-screen dark layout, no public navbar -->
<div class="min-h-screen bg-ck-black flex flex-col">

  <!-- Dashboard Navbar -->
  <header class="bg-ck-card border-b border-ck-border px-6 md:px-10 py-4 flex items-center justify-between sticky top-0 z-40">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-md bg-ck-yellow flex items-center justify-center">
        <span class="text-ck-black font-bold text-xs">CL</span>
      </div>
      <span class="text-ck-cream font-semibold">Creek<span class="text-ck-yellow">Link</span></span>
      <span class="hidden sm:block text-ck-border mx-3">|</span>
      <span class="hidden sm:block text-ck-muted text-sm">Driver Dashboard</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center gap-2 text-sm text-ck-muted">
        <span class="w-2 h-2 rounded-full bg-ck-yellow animate-pulse"></span>
        <%= driver.name %>
      </div>
      <a href="/logout" class="btn-tertiary text-sm text-ck-muted hover:text-ck-cream transition-colors">
        Sign out →
      </a>
    </div>
  </header>

  <!-- Main content -->
  <main class="flex-1 p-6 md:p-10 max-w-7xl mx-auto w-full">

    <!-- Welcome -->
    <div class="mb-8">
      <h1 class="text-white font-bold text-2xl md:text-3xl mb-1">
        Good <%= new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 18 ? 'afternoon' : 'evening' %>, <span class="text-ck-yellow"><%= driver.name.split(' ')[0] %>.</span>
      </h1>
      <p class="text-white/50 text-sm">Here are your assigned bookings. Pull-to-refresh for live updates.</p>
    </div>

    <!-- Stat chips -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <%
        const total     = bookings.length;
        const pending   = bookings.filter(b => b.status === 'pending').length;
        const confirmed = bookings.filter(b => b.status === 'confirmed').length;
        const completed = bookings.filter(b => b.status === 'completed').length;
      %>
      <% [
        ['Total', total,     '#1A1510'],
        ['Pending', pending, '#6B6560'],
        ['Confirmed', confirmed, '#F4B400'],
        ['Completed', completed, '#C9A84C'],
      ].forEach(([label, count, color]) => { %>
      <div class="bg-ck-card border border-ck-border rounded-xl p-5">
        <p class="text-ck-muted text-xs font-semibold uppercase tracking-wide mb-2"><%= label %></p>
        <p class="font-bold text-3xl" style="color:<%= color %>"><%= count %></p>
      </div>
      <% }) %>
    </div>

    <!-- Bookings table -->
    <div class="bg-ck-card border border-ck-border rounded-2xl overflow-hidden">
      <div class="px-6 py-5 border-b border-ck-border flex items-center justify-between">
        <h2 class="text-ck-cream font-semibold text-lg">Bookings</h2>
        <a href="/book" class="btn-primary text-xs px-4 py-2">+ New booking</a>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ck-border">
              <% ['Passenger', 'Pickup', 'Drop-off', 'Date', 'Time', 'Service', 'Status'].forEach(col => { %>
              <th class="text-left text-ck-muted text-xs font-semibold uppercase tracking-wider px-6 py-4"><%= col %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach((b, i) => { %>
            <tr class="border-b border-ck-border hover:bg-ck-card-hover transition-colors duration-150 <%= i % 2 === 0 ? '' : 'bg-ck-black/20' %>">
              <td class="px-6 py-4">
                <div>
                  <p class="text-ck-cream font-medium"><%= b.fullName %></p>
                  <p class="text-ck-muted text-xs mt-0.5"><%= b.email || '' %></p>
                </div>
              </td>
              <td class="px-6 py-4 text-ck-muted max-w-[140px]">
                <span class="line-clamp-2"><%= b.pickup %></span>
              </td>
              <td class="px-6 py-4 text-ck-muted max-w-[140px]">
                <span class="line-clamp-2"><%= b.dropoff %></span>
              </td>
              <td class="px-6 py-4 text-ck-muted whitespace-nowrap">
                <%= new Date(b.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
              </td>
              <td class="px-6 py-4 text-ck-muted"><%= b.time %></td>
              <td class="px-6 py-4">
                <span class="text-xs font-semibold text-ck-cream capitalize"><%= b.serviceType %></span>
              </td>
              <td class="px-6 py-4">
                <span class="badge-<%= b.status %>"><%= b.status.charAt(0).toUpperCase() + b.status.slice(1) %></span>
              </td>
            </tr>
            <% }) %>
            <% if (!bookings.length) { %>
            <tr>
              <td colspan="7" class="px-6 py-12 text-center text-ck-muted">No bookings yet.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="px-6 py-4 border-t border-ck-border flex items-center justify-between text-xs text-ck-muted">
        <span>Showing <%= bookings.length %> booking<%= bookings.length !== 1 ? 's' : '' %></span>
        <span class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-ck-yellow animate-pulse"></span>
          Live data
        </span>
      </div>
    </div>

  </main>
</div>

<link rel="stylesheet" href="/css/main.css" />
</body>
</html>
