<%- include('partials/head', { title, useThree: false }) %>
<%- include('partials/navbar') %>

<section class="bg-white min-h-screen pt-32 pb-20">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="text-center mb-14">
      <p class="section-label mb-3">Get in touch</p>
      <h1 class="font-bold text-ck-cream mb-4" style="font-size:clamp(28px,4vw,44px);line-height:1.2">
        Let's talk about your <span class="text-ck-yellow">fleet.</span>
      </h1>
      <p class="text-ck-muted max-w-md mx-auto">Whether you're running 5 vehicles or 500, we'd like to hear about your operation.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

      <!-- Left: form (3 cols) -->
      <div class="lg:col-span-3">
        <% if (success) { %>
        <div class="bg-ck-card border border-ck-yellow/40 rounded-xl p-10 text-center">
          <div class="w-16 h-16 rounded-full bg-ck-yellow/10 border-2 border-ck-yellow flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" class="route-line drawn"/>
            </svg>
          </div>
          <h2 class="text-ck-cream text-2xl font-bold mb-2">Message sent!</h2>
          <p class="text-ck-muted text-sm mb-6">We'll reply within 2 business hours — usually much sooner.</p>
          <a href="/contact" class="btn-primary text-sm">Send another →</a>
        </div>
        <% } else { %>

        <% if (error) { %>
        <div class="bg-red-900/20 border border-red-800/40 rounded-lg p-4 mb-6 text-red-400 text-sm"><%= error %></div>
        <% } %>

        <div class="bg-ck-dark border border-ck-border rounded-2xl p-8 md:p-10">
          <form action="/contact" method="POST" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">

              <div class="ck-input-wrap">
                <label class="block text-ck-muted text-xs font-semibold tracking-wider uppercase mb-2" for="c-name">Name</label>
                <input class="ck-input" type="text" id="c-name" name="name" placeholder="James Harrington" required />
              </div>

              <div class="ck-input-wrap">
                <label class="block text-ck-muted text-xs font-semibold tracking-wider uppercase mb-2" for="c-email">Email</label>
                <input class="ck-input" type="email" id="c-email" name="email" placeholder="james@company.co.uk" required />
              </div>

              <div class="ck-input-wrap">
                <label class="block text-ck-muted text-xs font-semibold tracking-wider uppercase mb-2" for="c-phone">Phone</label>
                <input class="ck-input" type="tel" id="c-phone" name="phone" placeholder="+44 7700 900000" />
              </div>

              <div class="ck-input-wrap">
                <label class="block text-ck-muted text-xs font-semibold tracking-wider uppercase mb-2" for="c-subject">Subject</label>
                <input class="ck-input" type="text" id="c-subject" name="subject" placeholder="Fleet partnership enquiry" />
              </div>

              <div class="ck-input-wrap sm:col-span-2">
                <label class="block text-ck-muted text-xs font-semibold tracking-wider uppercase mb-2" for="c-message">Message</label>
                <textarea class="ck-input resize-none" id="c-message" name="message" rows="5"
                          placeholder="Tell us about your fleet size, current challenges and what you're looking for..." required></textarea>
              </div>

            </div>
            <button type="submit" class="btn-primary mt-8 text-base px-8 py-4">Send message →</button>
          </form>
        </div>
        <% } %>
      </div>

      <!-- Right: company info (2 cols) -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Info card -->
        <div class="bg-ck-card border border-ck-border rounded-xl p-7">
          <h3 class="text-ck-cream font-semibold text-lg mb-5">Contact information</h3>
          <ul class="space-y-5">
            <% [
              ['Email','hello@creeklink.com','M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z','mailto:hello@creeklink.com'],
              ['Phone','+92 03030533693','M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z','tel:+923030533693'],
              ['WhatsApp','Chat with us now','M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z','https://wa.me/923030533693'],
              ['Hours','24 / 7 — 365 days','M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',null],
            ].forEach(([label,val,path,href]) => { %>
            <li class="flex items-start gap-4">
              <div class="w-9 h-9 rounded-lg bg-ck-yellow/10 border border-ck-yellow/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/>
                </svg>
              </div>
              <div>
                <p class="text-ck-muted text-xs font-semibold uppercase tracking-wide mb-0.5"><%= label %></p>
                <% if (href) { %>
                <a href="<%= href %>" class="text-ck-cream text-sm hover:text-ck-yellow transition-colors"><%= val %></a>
                <% } else { %>
                <p class="text-ck-cream text-sm"><%= val %></p>
                <% } %>
              </div>
            </li>
            <% }) %>
          </ul>
        </div>

        <!-- Map placeholder with dark filter -->
        <div class="rounded-xl overflow-hidden border border-ck-border relative">
          <div class="absolute inset-0 bg-ck-black/40 z-10 pointer-events-none"></div>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2482.975!2d-0.1278!3d51.5074!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47d8a00baf21de75%3A0x52963a5addd52a99!2sLondon%2C%20UK!5e0!3m2!1sen!2suk!4v1"
            width="100%" height="220" style="border:0;filter:grayscale(100%) invert(90%) contrast(80%);"
            allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="CreekLink operations location"></iframe>
        </div>

        <!-- Response time badge -->
        <div class="bg-ck-card border border-ck-border rounded-xl p-5 flex items-center gap-4">
          <div class="w-3 h-3 rounded-full bg-ck-yellow animate-pulse flex-shrink-0"></div>
          <div>
            <p class="text-ck-cream font-semibold text-sm">Average response time</p>
            <p class="text-ck-yellow font-bold text-lg">Under 2 hours</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<%- include('partials/whatsapp-fab') %>
<script src="/js/main.js" defer></script>
<script src="/js/borderglow.js" defer></script>
</body>
</html>
