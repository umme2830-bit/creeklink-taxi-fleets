<%- include('partials/head', { title, useThree: false }) %>
<%- include('partials/navbar') %>

<!-- ══ PAGE HERO ═══════════════════════════════════════════════════════════ -->
<section class="bg-white pt-36 pb-20 relative overflow-hidden">
  <!-- UK map motif -->
  <div class="absolute right-0 top-0 bottom-0 w-1/2 uk-map-bg opacity-40 pointer-events-none" aria-hidden="true"></div>
  <!-- Route line SVG -->
  <svg class="absolute left-0 top-1/2 -translate-y-1/2 opacity-20 pointer-events-none" width="300" height="2" aria-hidden="true">
    <line x1="0" y1="1" x2="300" y2="1" stroke="#F4B400" stroke-width="1.5" stroke-dasharray="8 6" class="route-line"/>
  </svg>

  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <p class="section-label mb-3">What we offer</p>
    <h1 class="font-bold text-ck-cream mb-5" style="font-size:clamp(32px,5vw,52px);line-height:1.15">
      Services built for<br><span class="text-ck-yellow">UK taxi fleets.</span>
    </h1>
    <p class="text-ck-muted text-lg max-w-xl">
      Three service tiers, one reliable partner. Every option comes with full BPO back-office support.
    </p>
  </div>
</section>

<!-- ══ SERVICE CARDS — 3D flip ════════════════════════════════════════════ -->
<section class="bg-ck-dark py-24 relative">
  <!-- Subtle F4B400 UK map at 5% opacity -->
  <div class="absolute inset-0 uk-map-bg" style="opacity:0.05;" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Economy Cab -->
      <div class="flip-card h-96">
        <div class="flip-card-inner h-full">
          <!-- Front -->
          <div class="flip-card-front card-dark p-8 flex flex-col h-full">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-6" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);">
              <svg class="w-7 h-7 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
              </svg>
            </div>
            <h3 class="text-h3 font-semibold text-white mb-3">Economy Cab</h3>
            <p class="text-sm leading-relaxed flex-1" style="color:rgba(255,255,255,0.65);">Reliable, no-frills transport for everyday journeys across UK cities. Competitive rates, professional drivers.</p>
            <div class="mt-6 pt-6" style="border-top:1px solid rgba(255,255,255,0.10);">
              <p class="text-ck-yellow text-xs font-semibold tracking-wider uppercase mb-1">Economy</p>
              <p class="text-white text-lg font-semibold italic">The smart choice for every ride.</p>
            </div>
            <p class="text-xs mt-4 italic" style="color:rgba(255,255,255,0.38);">Hover to see full details →</p>
          </div>
          <!-- Back -->
          <div class="flip-card-back bg-ck-yellow rounded-xl p-8 flex flex-col justify-between h-full">
            <div>
              <h3 class="text-xl font-bold text-ck-black mb-4">Economy Cab — Details</h3>
              <ul class="space-y-2 text-ck-black text-sm">
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Up to 4 passengers</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Real-time GPS tracking</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Instant confirmation SMS</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> 24/7 BPO dispatch support</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Card &amp; cash accepted</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Baby seat on request</li>
              </ul>
            </div>
            <a href="/book?type=economy" class="mt-6 inline-flex items-center gap-2 bg-ck-black text-white font-semibold px-5 py-3 rounded-md text-sm hover:bg-ck-dark hover:text-ck-black transition-colors">
              Book Economy →
            </a>
          </div>
        </div>
      </div>

      <!-- Business Class -->
      <div class="flip-card h-96">
        <div class="flip-card-inner h-full">
          <div class="flip-card-front card-dark p-8 flex flex-col h-full relative" style="border-color:rgba(244,180,0,0.55);border-width:2px;">
            <!-- Popular badge -->
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-ck-yellow text-ck-black text-xs font-bold px-4 py-1 rounded-full">
              Most Popular
            </div>
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-6" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);">
              <svg class="w-7 h-7 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
              </svg>
            </div>
            <h3 class="text-h3 font-semibold text-white mb-3">Business Class</h3>
            <p class="text-sm leading-relaxed flex-1" style="color:rgba(255,255,255,0.65);">Premium vehicles, suited drivers and white-glove service for corporate travellers and executives.</p>
            <div class="mt-6 pt-6" style="border-top:1px solid rgba(255,255,255,0.10);">
              <p class="text-ck-yellow text-xs font-semibold tracking-wider uppercase mb-1">Business</p>
              <p class="text-white text-lg font-semibold italic">First class. Every mile.</p>
            </div>
            <p class="text-xs mt-4 italic" style="color:rgba(255,255,255,0.38);">Hover to see full details →</p>
          </div>
          <div class="flip-card-back bg-ck-yellow rounded-xl p-8 flex flex-col justify-between h-full">
            <div>
              <h3 class="text-xl font-bold text-ck-black mb-4">Business Class — Details</h3>
              <ul class="space-y-2 text-ck-black text-sm">
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Premium saloon or SUV</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Meet &amp; greet service</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Complimentary Wi-Fi</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Flight tracking (airports)</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Priority BPO queue</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Dedicated account manager</li>
              </ul>
            </div>
            <a href="/book?type=business" class="mt-6 inline-flex items-center gap-2 bg-ck-black text-white font-semibold px-5 py-3 rounded-md text-sm hover:bg-ck-dark hover:text-ck-black transition-colors">
              Book Business →
            </a>
          </div>
        </div>
      </div>

      <!-- Airport Transfer -->
      <div class="flip-card h-96">
        <div class="flip-card-inner h-full">
          <div class="flip-card-front card-dark p-8 flex flex-col h-full">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-6" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);">
              <svg class="w-7 h-7 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
              </svg>
            </div>
            <h3 class="text-h3 font-semibold text-white mb-3">Airport Transfer</h3>
            <p class="text-sm leading-relaxed flex-1" style="color:rgba(255,255,255,0.65);">Punctual airport pickups and drop-offs with real-time flight monitoring. Never miss a landing again.</p>
            <div class="mt-6 pt-6" style="border-top:1px solid rgba(255,255,255,0.10);">
              <p class="text-ck-yellow text-xs font-semibold tracking-wider uppercase mb-1">Airport</p>
              <p class="text-white text-lg font-semibold italic">Runway to road, seamlessly.</p>
            </div>
            <p class="text-xs mt-4 italic" style="color:rgba(255,255,255,0.38);">Hover to see full details →</p>
          </div>
          <div class="flip-card-back bg-ck-yellow rounded-xl p-8 flex flex-col justify-between h-full">
            <div>
              <h3 class="text-xl font-bold text-ck-black mb-4">Airport Transfer — Details</h3>
              <ul class="space-y-2 text-ck-black text-sm">
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> All major UK airports</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Live flight monitoring</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Free 60-min wait on delays</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Name board meet &amp; greet</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> Luggage assistance</li>
                <li class="flex items-center gap-2"><span class="font-bold">✓</span> 24/7 BPO flight desk</li>
              </ul>
            </div>
            <a href="/book?type=airport" class="mt-6 inline-flex items-center gap-2 bg-ck-black text-white font-semibold px-5 py-3 rounded-md text-sm hover:bg-ck-dark hover:text-ck-black transition-colors">
              Book Airport →
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══ BPO SUPPORT FEATURES ══════════════════════════════════════════════ -->
<section class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: text -->
      <div class="anim-fade-left">
        <p class="section-label mb-3">Behind every booking</p>
        <h2 class="section-title">Full BPO support<br>included in every tier.</h2>
        <p class="text-ck-muted text-base leading-relaxed mb-8">
          Every service tier comes backed by our UK-focused BPO operations centre. We handle every call, every query and every escalation — so your drivers stay on the road.
        </p>
        <ul class="space-y-4">
          <% [
            ['24/7 Dispatch', '24-hour call centre with native-English agents'],
            ['Booking Support', 'Real-time booking management and rebooking'],
            ['Driver Assistance', 'Licence checks, route support, incident reporting'],
            ['Reliable & Secure', 'ISO-aligned data handling and PCI-safe payments'],
          ].forEach(([title, desc]) => { %>
          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-md bg-ck-yellow/10 border border-ck-yellow/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
            </div>
            <div>
              <p class="text-ck-cream font-semibold text-sm"><%= title %></p>
              <p class="text-ck-muted text-sm"><%= desc %></p>
            </div>
          </li>
          <% }) %>
        </ul>
        <a href="/contact" class="btn-primary mt-8 inline-flex">Get support today →</a>
      </div>

      <!-- Right: icon grid -->
      <div class="grid grid-cols-2 gap-6 anim-fade-right">
        <% [
          ['Headset','24/7 Call Handling','M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z'],
          ['Calendar','Booking Desk','M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5'],
          ['Car','Driver Support','M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958'],
          ['Shield','Secure & Compliant','M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z'],
        ].forEach(([icon, label, path]) => { %>
        <div class="card-dark p-6 flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background:rgba(244,180,0,0.12);border:1px solid rgba(244,180,0,0.22);">
            <svg class="w-6 h-6 text-ck-yellow" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/>
            </svg>
          </div>
          <p class="text-white font-semibold text-sm"><%= label %></p>
        </div>
        <% }) %>
      </div>

    </div>
  </div>
</section>

<!-- ══ CTA ════════════════════════════════════════════════════════════════ -->
<section class="bg-ck-dark py-20 border-t border-ck-border">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="section-title">Ready to book your ride?</h2>
    <p class="section-sub mx-auto text-center mb-8">Our team is on standby — 24 hours a day, 7 days a week.</p>
    <a href="/book" class="btn-primary text-base px-8 py-4">Book a Ride Now →</a>
  </div>
</section>

<%- include('partials/footer') %>
<%- include('partials/whatsapp-fab') %>
<script src="/js/main.js" defer></script>
<script src="/js/borderglow.js" defer></script>
<script src="/js/tiltedcard.js" defer></script>
</body>
</html>
