        <p class="text-ck-muted text-sm leading-relaxed max-w-xs">Your passenger calls. Our agents answer instantly in your company's name — professionally, every single time.</p>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center text-center anim-fade-up" style="animation-delay:0.15s">
        <div class="w-16 h-16 rounded-full bg-ck-yellow flex items-center justify-center mb-6 relative z-10 shadow-glow-yellow">
