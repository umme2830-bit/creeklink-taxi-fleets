<!-- ══════════════════════════════════════════════════════════════════════════
     HOW IT WORKS
═══════════════════════════════════════════════════════════════════════════ -->
<section class="bg-white py-24 relative overflow-hidden">
  <!-- Subtle dot grid -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image:radial-gradient(circle,#F4B400 1px,transparent 1px);background-size:32px 32px;" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12">
    <div class="text-center mb-16">
      <p class="section-label">Simple process</p>
      <h2 class="section-title">How CreekLink works</h2>
      <p class="section-sub mx-auto text-center">From first call to completed ride — your operations run through us without friction.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-8 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-gradient-to-r from-transparent via-ck-border to-transparent" aria-hidden="true"></div>

      <!-- Step 1 -->
      <div class="flex flex-col items-center text-center anim-fade-up">
        <div class="w-16 h-16 rounded-full bg-ck-yellow flex items-center justify-center mb-6 relative z-10 shadow-glow-yellow">
