<!-- ══════════════════════════════════════════════════════════════════════════
     HERO — Premium SaaS-style white hero
═══════════════════════════════════════════════════════════════════════════ -->
<section id="hero" class="relative min-h-[100dvh] bg-white flex items-center overflow-hidden">

  <!-- Subtle dot grid -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true"
       style="background-image:radial-gradient(circle,rgba(13,13,13,0.055) 1px,transparent 1px);
              background-size:28px 28px;"></div>

  <!-- Yellow pinstripe at top -->
  <div class="absolute top-0 left-0 right-0 h-px pointer-events-none" aria-hidden="true"
       style="background:linear-gradient(90deg,transparent 0%,#F4B400 25%,#F4B400 75%,transparent 100%);opacity:0.75;"></div>

  <!-- Main content -->
  <div class="relative w-full max-w-7xl mx-auto px-6 md:px-12 pt-28 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_460px] gap-12 xl:gap-20 items-center">

      <!-- LEFT: TEXT -->
      <div>

        <!-- Status pill -->
        <div id="hero-pill" class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full mb-8"
             style="border:1px solid rgba(13,13,13,0.12);background:#FFFFFF;">
          <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 animate-pulse" style="background:#F4B400;"></span>
          <span class="text-xs font-semibold tracking-wide" style="color:rgba(13,13,13,0.58);">Taxi Dispatch & Call Answering — 24/7</span>
        </div>

        <!-- Headline -->
        <h1 id="hero-h1" class="font-bold mb-6"
            style="font-size:clamp(44px,5.6vw,80px);line-height:1.03;letter-spacing:-0.03em;color:#0D0D0D;">
          Never miss<br>a booking.<br>
          <span style="color:#F4B400;">Ever.</span>
        </h1>

        <!-- Subtext -->
        <p id="hero-sub" class="text-lg md:text-xl mb-10 max-w-[540px]"
           style="color:rgba(13,13,13,0.6);line-height:1.65;">
          CreekLink runs as a fully managed, 24/7 contact centre exclusively for UK taxi and private-hire operators — answering every call, confirming every booking, dispatching every driver.
        </p>

        <!-- CTAs -->
        <div id="hero-ctas" class="flex flex-col sm:flex-row gap-3.5 mb-14">
          <a href="/contact" class="btn-primary text-base px-8 py-4">Get Support →</a>
          <a href="/services"
             class="inline-flex items-center gap-2 px-8 py-4 rounded-md font-semibold text-base transition-all duration-200 hover:-translate-y-0.5"
             style="border:1px solid rgba(13,13,13,0.14);color:rgba(13,13,13,0.72);background:transparent;">
            View Services →
          </a>
        </div>

        <!-- Stats row -->
        <div id="hero-stats" class="flex flex-wrap items-center gap-x-6 gap-y-4 pt-6 border-t"
             style="border-color:rgba(13,13,13,0.08);">
          <div>
            <div class="text-xl font-bold" style="color:#0D0D0D;letter-spacing:-0.02em;">500+</div>
            <div class="text-xs font-medium mt-0.5" style="color:rgba(13,13,13,0.48);">Drivers supported</div>
          </div>
          <div class="w-px h-7 hidden sm:block" style="background:rgba(13,13,13,0.1);"></div>
          <div>
            <div class="text-xl font-bold" style="color:#0D0D0D;letter-spacing:-0.02em;">98%</div>
            <div class="text-xs font-medium mt-0.5" style="color:rgba(13,13,13,0.48);">Booking fulfilment</div>
          </div>
          <div class="w-px h-7 hidden sm:block" style="background:rgba(13,13,13,0.1);"></div>
          <div>
            <div class="text-xl font-bold" style="color:#0D0D0D;letter-spacing:-0.02em;">24/7</div>
            <div class="text-xs font-medium mt-0.5" style="color:rgba(13,13,13,0.48);">Always on</div>
          </div>
          <div class="w-px h-7 hidden sm:block" style="background:rgba(13,13,13,0.1);"></div>
          <div>
            <div class="text-xl font-bold" style="color:#0D0D0D;letter-spacing:-0.02em;">12</div>
            <div class="text-xs font-medium mt-0.5" style="color:rgba(13,13,13,0.48);">UK cities</div>
          </div>
        </div>

      </div>

      <!-- RIGHT: LIVE DISPATCH CARD -->
      <div id="hero-card" class="hidden lg:block relative">

        <!-- Main card -->
        <div class="rounded-2xl bg-white"
             style="border:1px solid rgba(13,13,13,0.07);
                    box-shadow:0 0 0 1px rgba(13,13,13,0.02),
                               0 2px 4px rgba(13,13,13,0.04),
                               0 8px 20px rgba(13,13,13,0.07),
                               0 24px 56px rgba(13,13,13,0.09),
                               0 48px 96px rgba(13,13,13,0.05);">

          <!-- Card header -->
          <div class="flex items-center justify-between px-5 pt-5 pb-4"
               style="border-bottom:1px solid rgba(13,13,13,0.06);">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full animate-pulse" style="background:#22c55e;"></div>
              <span class="text-sm font-semibold" style="color:#0D0D0D;">Live Dispatch</span>
            </div>
            <span class="text-xs" style="color:rgba(13,13,13,0.36);">Manchester · UK</span>
          </div>

          <!-- Booking rows -->
          <div class="px-4 py-3 space-y-1.5">

            <!-- Row 1: On Call -->
            <div class="flex items-center gap-3 px-2 py-2.5 rounded-xl"
                 style="background:rgba(13,13,13,0.022);">
              <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center"
                   style="background:rgba(244,180,0,0.12);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="#F4B400" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate" style="color:#0D0D0D;">J. Harrison</p>
                <p class="text-xs truncate" style="color:rgba(13,13,13,0.45);">Heathrow → City Centre</p>
              </div>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0"
                    style="background:#0D0D0D;color:#FFFFFF;">On Call</span>
            </div>

            <!-- Row 2: Confirmed -->
            <div class="flex items-center gap-3 px-2 py-2.5 rounded-xl"
                 style="background:rgba(13,13,13,0.022);">
              <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center"
                   style="background:rgba(13,13,13,0.04);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="rgba(13,13,13,0.45)" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate" style="color:#0D0D0D;">S. Clarke</p>
                <p class="text-xs truncate" style="color:rgba(13,13,13,0.45);">Manchester → Hotel</p>
              </div>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0"
                    style="background:rgba(13,13,13,0.07);color:rgba(13,13,13,0.75);">Confirmed</span>
            </div>

            <!-- Row 3: Pending -->
            <div class="flex items-center gap-3 px-2 py-2.5 rounded-xl"
                 style="background:rgba(13,13,13,0.022);">
              <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center"
                   style="background:rgba(13,13,13,0.04);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="rgba(13,13,13,0.35)" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate" style="color:#0D0D0D;">A. Patel</p>
                <p class="text-xs truncate" style="color:rgba(13,13,13,0.45);">Birmingham → Airport</p>
              </div>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0"
                    style="background:#FFFFFF;border:1px solid rgba(13,13,13,0.14);color:rgba(13,13,13,0.68);">Pending</span>
            </div>

            <!-- Row 4: Completed (dimmed) -->
            <div class="flex items-center gap-3 px-2 py-2.5 rounded-xl">
              <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center"
                   style="background:rgba(13,13,13,0.03);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="rgba(13,13,13,0.28)" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold truncate" style="color:rgba(13,13,13,0.42);">T. Reynolds</p>
                <p class="text-xs truncate" style="color:rgba(13,13,13,0.28);">London → Luton</p>
              </div>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full flex-shrink-0"
                    style="background:#0D0D0D;color:#FFFFFF;">Completed</span>
            </div>

          </div>

          <!-- Card footer metric -->
          <div class="px-5 py-4 flex items-center justify-between"
               style="border-top:1px solid rgba(13,13,13,0.06);">
            <span class="text-xs" style="color:rgba(13,13,13,0.38);">Today's dispatches</span>
            <div class="flex items-baseline gap-1.5">
              <span class="text-xl font-bold" style="color:#0D0D0D;letter-spacing:-0.02em;">247</span>
              <span class="text-xs font-semibold" style="color:#F4B400;">↑ 12%</span>
            </div>
          </div>
        </div>

        <!-- Floating chip: calls in queue -->
        <div class="absolute -top-3.5 right-5 bg-white rounded-xl px-3.5 py-2.5 flex items-center gap-2"
             style="border:1px solid rgba(13,13,13,0.09);
                    box-shadow:0 2px 8px rgba(13,13,13,0.07),0 8px 24px rgba(13,13,13,0.06);">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#22c55e;"></span>
          <span class="text-xs font-semibold" style="color:#0D0D0D;">3 calls in queue</span>
        </div>

        <!-- Floating chip: dispatch speed -->
        <div class="absolute -bottom-4 left-5 bg-white rounded-xl px-3.5 py-2.5"
             style="border:1px solid rgba(13,13,13,0.09);
                    box-shadow:0 2px 8px rgba(13,13,13,0.07),0 8px 24px rgba(13,13,13,0.06);">
          <span class="text-xs font-semibold" style="color:#0D0D0D;">&#x2713; We never miss your call</span>
        </div>

      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 pointer-events-none" aria-hidden="true">
    <span class="text-[10px] font-semibold tracking-[0.18em] uppercase" style="color:rgba(13,13,13,0.32);">Scroll</span>
    <div class="w-px h-7" style="background:linear-gradient(to bottom,rgba(13,13,13,0.28),transparent);"></div>
  </div>

  <!-- Hero entrance animation -->
  <script>
    (function heroEntrance() {
      if (typeof gsap === 'undefined') { setTimeout(heroEntrance, 80); return; }
      if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
      var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.from('#hero-pill',  { opacity: 0, y: 18, duration: 0.5 }, 0.15)
        .from('#hero-h1',    { opacity: 0, y: 28, duration: 0.7 }, 0.28)
        .from('#hero-sub',   { opacity: 0, y: 22, duration: 0.6 }, 0.46)
        .from('#hero-ctas',  { opacity: 0, y: 16, duration: 0.55 }, 0.58)
        .from('#hero-stats', { opacity: 0, y: 14, duration: 0.5 }, 0.7)
        .from('#hero-card',  { opacity: 0, x: 36, duration: 0.75, ease: 'power2.out' }, 0.36);
    })();
  </script>
</section>

